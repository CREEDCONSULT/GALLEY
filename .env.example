# Convex — from `npx convex dev` (writes these into .env.local automatically)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Set on the Convex deployment (not here) via `npx convex env set`:
#   JWT_PRIVATE_KEY, JWKS  — Convex Auth signing keys (npx @convex-dev/auth)
#   SITE_URL               — the app's public origin (e.g. https://galley.up.railway.app)
